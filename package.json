{
  "name": "abel-drive",
  "version": "0.1.15",
  "description": "Abel Drive — acesso aos arquivos do Ecossistema Abel como um drive no computador.",
  "author": "Abel Design",
  "license": "UNLICENSED",
  "private": true,
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "dist:mac": "electron-builder --mac"
  },
  "dependencies": {
    "electron-updater": "^6.1.8"
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "br.com.abeldesign.abeldrive",
    "productName": "Abel Drive",
    "publish": [
      { "provider": "github", "owner": "AdmAbelDesign", "repo": "abel-drive", "releaseType": "release" }
    ],
    "files": [
      "src/**/*",
      "build/icon.png",
      "package.json"
    ],
    "extraResources": [
      { "from": "bin", "to": "bin", "filter": ["**/*"] }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "artifactName": "Abel-Drive-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Abel Drive"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png",
      "category": "public.app-category.productivity",
      "identity": null
    }
  }
}
